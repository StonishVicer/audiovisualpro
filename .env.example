# ===========================================
# AudiovisualPro — Variables de Entorno
# ===========================================
# Copia este archivo como .env y configura los valores

# Base de datos
DB_HOST=localhost
DB_USER=postgres
DB_PASS=admin123
DB_NAME=audiovisualpro_db
DB_PORT=5432

# JWT
JWT_SECRET=un_secreto_muy_largo_y_seguro_para_jwt

# Puerto del servidor
PORT=3000

# Entorno (development | production)
NODE_ENV=development

# Nivel de log (error | warn | info | debug)
LOG_LEVEL=info

# Orígenes CORS permitidos (separados por coma)
# Ejemplo produccion: https://miapp.com
CORS_ORIGINS=http://localhost:5173,http://localhost

# URL base del servidor (para generar links de archivos)
# En produccion usar dominio real: https://api.miapp.com
SERVER_URL=http://localhost:3000
